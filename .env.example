# Server
PORT=3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# WorkOS
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Database
MONGODB_URI=

# Polar checkout
# Ask your Polar organization manager for an organization access token and
# the product IDs. Leave these blank until access is granted; the billing UI
# will remain visible, but checkout buttons will be disabled.
POLAR_SERVER=sandbox
# Keep false until the signed webhook route can fulfill purchases.
POLAR_CHECKOUT_ENABLED=false
POLAR_ACCESS_TOKEN=
POLAR_STARTER_PRODUCT_ID=
POLAR_PLUS_PRODUCT_ID=
POLAR_PRO_PRODUCT_ID=

# Add this later when the signed webhook endpoint is implemented.
POLAR_WEBHOOK_SECRET=
